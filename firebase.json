{
  "hosting": {
    "public": ".",
    "headers": [
      {
        "source": "**/*.@(js|css|json)",
        "headers": [
          {
            "key": "Cache-Control",
            "value": "no-cache, no-store, must-revalidate"
          }
        ]
      }
    ],
    "ignore": [
      "firebase.json",
      "**/.*",
      "**/node_modules/**",
      "scripts/**",
      "tmp/**",
      "ab900new/**",
      "az-questions.json",
      "az-full-questions.json",
      "AZ-900-Questions-Verified.csv",
      "AZ-900-Questions-Verified.json",
      "test-blob.js",
      "README.md",
      "package.json",
      "package-lock.json"
    ]
  }
}
